{
  "name": "marknext",
  "displayName": "MarkNext",
  "description": "Syntax highlighting for MarkNext - a minimal, unambiguous, and secure Markdown successor",
  "version": "1.0.0",
  "publisher": "marknext",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "marknext",
    "markdown",
    "markup",
    "documentation"
  ],
  "icon": "icon.png",
  "activationEvents": [
    "onLanguage:marknext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "marknext",
        "aliases": [
          "MarkNext",
          "marknext"
        ],
        "extensions": [
          ".mnext",
          ".mn"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "marknext",
        "scopeName": "text.marknext",
        "path": "./syntaxes/marknext.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.javascript": "javascript",
          "meta.embedded.block.typescript": "typescript",
          "meta.embedded.block.python": "python",
          "meta.embedded.block.rust": "rust",
          "meta.embedded.block.css": "css",
          "meta.embedded.block.html": "html"
        }
      }
    ],
    "configuration": {
      "type": "object",
      "title": "MarkNext",
      "properties": {
        "marknext.preview.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable MarkNext preview"
        }
      }
    },
    "commands": [
      {
        "command": "marknext.preview",
        "title": "Preview MarkNext",
        "icon": "$(open-preview)"
      },
      {
        "command": "marknext.exportHtml",
        "title": "Export to HTML",
        "icon": "$(save)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .mnext || resourceExtname == .mn",
          "command": "marknext.preview",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "16.x",
    "typescript": "^4.4.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/skorotkiewicz/marknext"
  }
}
