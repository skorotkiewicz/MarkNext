{
  "comments": {
    "lineComment": "%"
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["```", "```"],
    ["`", "`"]
  ],
  "autoClosingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["`", "`"],
    ["*", "*"],
    ["/", "/"]
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["`", "`"],
    ["*", "*"],
    ["/", "/"]
  ],
  "folding": {
    "offSide": true,
    "markers": {
      "start": "^#+",
      "end": "^(#+|```)$"
    }
  },
  "wordPattern": "([a-zA-Z0-9_-]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*[-|]\\s",
    "decreaseIndentPattern": "^\\s*[-|]\\s"
  }
}
