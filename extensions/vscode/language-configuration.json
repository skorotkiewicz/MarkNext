{
  "comments": {
    "lineComment": "% "
  },
  "brackets": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["```", "```"],
    ["`", "`"]
  ],
  "autoClosingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["`", "`"],
    ["*", "*"],
    ["/", "/"],
    ["$", "$"]
  ],
  "autoCloseBefore": ".;:.,=}])>` /$\\n",
  "surroundingPairs": [
    ["[", "]"],
    ["(", ")"],
    ["{", "}"],
    ["`", "`"],
    ["*", "*"],
    ["/", "/"],
    ["$", "$"],
    ["\"", "\""]
  ],
  "folding": {
    "offSide": false,
    "markers": {
      "start": "^#+|^\\$\\$|^```",
      "end": "^(#+|```|\\$\\$)$"
    }
  },
  "wordPattern": "([a-zA-Z0-9_-]+)",
  "indentationRules": {
    "increaseIndentPattern": "^\\s*[-|>]\\s",
    "decreaseIndentPattern": "^\\s*(<\\/?[^>]+>.*)$"
  }
}
