{
  "name": "marknext",
  "version": "1.0.0",
  "description": "A minimal, unambiguous, and secure Markdown successor. Context-free grammar parser with no inline HTML.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "MARKNEXT_SPEC.md",
    "QUICKREF.md",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir ./dist",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "dev": "bun run index.ts",
    "compile": "bun run src/index.ts",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "markdown",
    "marknext",
    "parser",
    "lexer",
    "ast",
    "markup",
    "documentation",
    "commonmark",
    "context-free-grammar",
    "secure",
    "xss-protection"
  ],
  "author": "Sebastian Korotkiewicz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skorotkiewicz/marknext.git"
  },
  "bugs": {
    "url": "https://github.com/skorotkiewicz/marknext/issues"
  },
  "homepage": "https://github.com/skorotkiewicz/marknext",
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.0.0"
  }
}
